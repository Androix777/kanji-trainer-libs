{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"]
	},
	"include": ["src", "demo"]
}
